# ============================================================================
# KAZA — PRODUCTION environment template (NAMES ONLY — never commit real values)
# ----------------------------------------------------------------------------
# The real file lives ONLY on the VPS at /opt/kaza/env/.env.production (chmod 600)
# and is passed to compose via:  docker compose -f docker-compose.prod.yml --env-file ...
# `.env` / `.env.*` are git-ignored; this `.env.example` is the only tracked one.
# ============================================================================

# ── Public domains (used by Nginx vhosts AND baked into frontend build-args) ──
PORTFOLIO_DOMAIN=kaza.example.com           # demo / public storefront
PORTAL_DOMAIN=app.kaza.example.com          # rental-platform / portals
API_DOMAIN=api.kaza.example.com             # .NET API
CERTBOT_EMAIL=admin@kaza.example.com        # Let's Encrypt account / expiry notices

# ── PostgreSQL (db service) ──
POSTGRES_DB=RentalPlatform
POSTGRES_USER=kaza_prod                      # do NOT reuse the dev 'postgres' user
POSTGRES_PASSWORD=__SET_A_STRONG_SECRET__    # rotate; never reuse the burned dev password

# ── API (.NET) — these OVERRIDE the image defaults at runtime ──
ASPNETCORE_ENVIRONMENT=Production
# Connection string points at the internal 'db' service name (never 'localhost').
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=RentalPlatform;Username=kaza_prod;Password=__SET_A_STRONG_SECRET__
# JWT — generate fresh; the dev secret committed in docker-compose.yml is BURNED.
Jwt__Secret=__SET_A_STRONG_64_CHAR_SECRET__
Jwt__Issuer=KazaBooking
Jwt__Audience=KazaBooking
# CORS — exact production origins only (appsettings.Production.json ships empty).
Cors__AllowedOrigins__0=https://kaza.example.com
Cors__AllowedOrigins__1=https://app.kaza.example.com

# ── Frontend build-args (BAKED AT BUILD TIME — change requires image rebuild) ──
# STORAGE_URL is intentionally EMPTY so unit-image src becomes relative '/uploads/...'
# (served same-origin via the Nginx /uploads proxy) — see Blocker B2.
NEXT_PUBLIC_STORAGE_URL=
NEXT_PUBLIC_MAPBOX_TOKEN=                     # optional; portal map. Empty disables the map.

# ── Reserved for a FUTURE notification channel (NOT implemented yet) ──
# Revoke + reissue any previously exposed token before placing it here.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
